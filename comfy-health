#!/usr/bin/env bash
set -euo pipefail

# comfy-health — friendly CLI wrapper for desloppify
# Maps user-friendly subcommands to desloppify internals.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_PATH="${COMFY_FRONTEND_PATH:-.}"
LOG_FILE="${COMFY_HEALTH_LOG:-$SCRIPT_DIR/.comfy-health.log}"

# Source shared libraries
source "$SCRIPT_DIR/lib/helpers.sh"
source "$SCRIPT_DIR/lib/commands.sh"

# ── Score logging ──
log_run() {
  local subcmd="$1" issues="${2:-}" notes="${3:-}"
  local ts branch commit
  ts=$(date -u +%Y-%m-%dT%H:%M:%SZ)
  branch=$(cd "$PROJECT_PATH" && git symbolic-ref --short HEAD 2>/dev/null || echo "detached")
  commit=$(cd "$PROJECT_PATH" && git rev-parse --short HEAD 2>/dev/null || echo "unknown")
  echo -e "${ts}\t${branch}\t${commit}\t${subcmd}\t${issues}\t${notes}" >> "$LOG_FILE"
}

usage() {
  cat <<'EOF'
comfy-health — ComfyUI frontend health checker

Usage:
  comfy-health scan [options]         Run all detectors, update state, show diff
  comfy-health check [options]        Run subjective review (assess code quality dimensions)
  comfy-health status                 Full project dashboard: score, dimensions, progress
  comfy-health show <pattern>         Dig into issues by file, directory, detector, or ID
  comfy-health next                   Show next priority item from the living plan
  comfy-health backlog                Show broader backlog items
  comfy-health plan                   View/update the living plan
  comfy-health tree                   Annotated codebase tree
  comfy-health viz                    Generate interactive HTML treemap
  comfy-health diff [REF]             Scan only files changed since REF (default: HEAD~1)
  comfy-health branch [BASE]          Scan files changed vs BASE branch (default: main)
  comfy-health doctor                 Self-check: verify deps, config, project setup
  comfy-health lint-review [--base=B] Deterministic code review (fallback for rate-limited code_review)
  comfy-health --cleanup              Remove generated artifacts (.desloppify/, scorecard.png, etc.)

Scope options (diff/branch/lint-review):
  --since=2d                          Scope to commits in last N days/weeks (e.g. 2d, 1w)
  --commits=N                         Scope to last N commits on current branch
  --upstream                          Fetch and compare against upstream/main (or origin/main)
  --list-files                        Just print changed file manifest and exit
  --copy-to=PATH                      Copy changed files to target repo (with verify)
  --strict                            Exit non-zero if issues found

Options (scan/show):
  --branch [BASE]                     Scope to branch-changed files only (default base: main)

Options (scan):
  --skip-slow                         Skip slow detectors (duplicates)
  --no-badge                          Skip scorecard image generation
  --profile {objective,full,ci}       Scan profile

Options (check):
  --prepare                           Generate review packet for subjective dimensions
  --import FILE                       Import completed review
  --branch [BASE]                     Scope review to branch changes only

Pass-through:
  Any unrecognized subcommand or flag is forwarded directly to desloppify.

Environment:
  COMFY_FRONTEND_PATH                 Project root (default: current directory)

Examples:
  comfy-health scan                   Full repo scan
  comfy-health scan --skip-slow       Skip duplicate detection
  comfy-health check                  Assess subjective quality dimensions
  comfy-health check --branch         Scope review to branch changes vs main
  comfy-health show styling           Show all styling issues
  comfy-health show src/stores/       Show issues in a directory
  comfy-health diff                   Issues in files changed since HEAD~1
  comfy-health diff HEAD~5            Issues in files changed in last 5 commits
  comfy-health branch                 Issues in files changed vs main
  comfy-health branch develop         Issues in files changed vs develop
  comfy-health branch --since=2d      Issues from last 2 days of commits
  comfy-health branch --commits=10    Issues from last 10 commits
  comfy-health branch --upstream      Compare against upstream/main
  comfy-health branch --list-files     List files to copy for PR
  comfy-health branch --copy-to=/path Copy changed files to PR repo (verified)
  comfy-health scan --branch          Scan only branch-changed files
  comfy-health show --branch styling  Show branch issues matching pattern
  comfy-health next                   Get next priority fix
  comfy-health status                 Full dashboard
  comfy-health doctor                 Check deps and project setup
  comfy-health --cleanup              Remove all generated artifacts
  comfy-health --version              Show version
EOF
}

cmd="${1:-}"
case "$cmd" in
  -h|--help|help|"")
    usage
    exit 0
    ;;
  -v|--version|version)
    ver=$(git -C "$SCRIPT_DIR" describe --tags 2>/dev/null || git -C "$SCRIPT_DIR" rev-parse --short HEAD 2>/dev/null || echo "dev")
    echo "comfy-health $ver"
    exit 0
    ;;
  --cleanup|cleanup)
    proj=$(cd "$PROJECT_PATH" 2>/dev/null && pwd)
    removed=0
    for target in \
      "$proj/.desloppify" \
      "$proj/scorecard.png" \
      "$proj/.claude/skills/desloppify" \
      "$proj/query.json" \
    ; do
      if [[ -e "$target" ]]; then
        rm -rf "$target"
        echo "Removed: $target"
        removed=$((removed + 1))
      fi
    done
    if [[ $removed -eq 0 ]]; then
      echo "Nothing to clean up."
    else
      echo "Cleaned up $removed artifact(s)."
    fi
    exit 0
    ;;
  check)
    shift
    cmd_check "$@"
    ;;
  diff)
    shift
    cmd_diff "$@"
    ;;
  branch)
    shift
    cmd_branch "$@"
    ;;
  lint-review)
    shift
    cmd_lint_review "$@"
    ;;
  doctor)
    errors=0

    # Python version
    if py_ver=$(python3 --version 2>/dev/null | awk '{print $2}'); then
      py_major=$(echo "$py_ver" | cut -d. -f1)
      py_minor=$(echo "$py_ver" | cut -d. -f2)
      if [[ "$py_major" -ge 3 && "$py_minor" -ge 11 ]]; then
        echo "✓ Python $py_ver"
      else
        echo "✗ Python $py_ver (need 3.11+)"
        errors=$((errors + 1))
      fi
    else
      echo "✗ Python 3 not found"
      errors=$((errors + 1))
    fi

    # desloppify importable
    if ds_ver=$(python3 -c "import desloppify; print(desloppify.__version__)" 2>/dev/null); then
      echo "✓ desloppify $ds_ver"
    elif python3 -c "import desloppify" 2>/dev/null; then
      echo "✓ desloppify (version unknown)"
    else
      echo "✗ desloppify not importable (pip install desloppify)"
      errors=$((errors + 1))
    fi

    # Project path and frontend files
    proj=$(cd "$PROJECT_PATH" 2>/dev/null && pwd)
    if [[ -d "$proj" ]]; then
      vue_count=$(find "$proj" -name '*.vue' 2>/dev/null | wc -l | tr -d ' ')
      ts_count=$(find "$proj" -name '*.ts' 2>/dev/null | wc -l | tr -d ' ')
      if [[ "$vue_count" -gt 0 || "$ts_count" -gt 0 ]]; then
        echo "✓ Project: $proj ($vue_count .vue, $ts_count .ts files)"
      else
        echo "✗ Project: $proj (no .vue or .ts files found)"
        errors=$((errors + 1))
      fi
    else
      echo "✗ Project path not found: $PROJECT_PATH"
      errors=$((errors + 1))
    fi

    # .desloppify state directory
    if [[ -d "$proj/.desloppify" ]]; then
      echo "✓ State: $proj/.desloppify"
    else
      echo "⚠ No .desloppify/ state — run 'comfy-health scan' first"
    fi

    # Git
    if command -v git &>/dev/null; then
      if git -C "$proj" rev-parse --is-inside-work-tree &>/dev/null; then
        git_branch=$(git -C "$proj" symbolic-ref --short HEAD 2>/dev/null || echo "detached")
        if git -C "$proj" diff --quiet 2>/dev/null && git -C "$proj" diff --cached --quiet 2>/dev/null; then
          echo "✓ Git: $git_branch branch, clean"
        else
          echo "✓ Git: $git_branch branch, dirty"
        fi
      else
        echo "⚠ Not a git repository: $proj"
      fi
    else
      echo "✗ Git not found"
      errors=$((errors + 1))
    fi

    exit $errors
    ;;
  # Scan with optional --branch scoping
  scan)
    shift
    has_branch=false
    branch_base="main"
    scan_args=()
    for arg in "$@"; do
      case "$arg" in
        --branch) has_branch=true ;;
        --branch=*) has_branch=true; branch_base="${arg#--branch=}" ;;
        *) scan_args+=("$arg") ;;
      esac
    done

    if $has_branch; then
      # Scoped scan: only branch-changed files
      parse_scope_flags "$branch_base" "${scan_args[@]}"
      resolve_scope_ref "$_BASE"
      ref="$_RESOLVED_REF"
      get_changed_files "$ref"
      all_files=$(echo -e "${_NEW_FILES}\n${_MOD_FILES}" | grep -v '^$' | sort -u || true)
      if [[ -z "$all_files" ]]; then
        echo "No changed .vue/.ts files vs $_BASE — nothing to scan."
        exit 0
      fi
      tmpdir=$(mktemp -d)
      trap "rm -rf $tmpdir" EXIT
      while IFS= read -r f; do
        if [[ -n "$f" && -f "$PROJECT_PATH/$f" ]]; then
          mkdir -p "$tmpdir/$(dirname "$f")"
          cp "$PROJECT_PATH/$f" "$tmpdir/$f"
        fi
      done <<< "$all_files"
      new_count=$(count_lines "$_NEW_FILES")
      mod_count=$(count_lines "$_MOD_FILES")
      echo "Branch-scoped scan: $new_count new, $mod_count modified files vs $_BASE"
      log_run "scan" "" "started branch:$_BASE"
      python3 -m desloppify scan --path "$tmpdir" "${scan_args[@]}"
      rc=$?
      log_run "scan" "" "exit:$rc branch:$_BASE"
      exit $rc
    else
      log_run "$cmd" "" "started"
      python3 -m desloppify scan --path "$PROJECT_PATH" "${scan_args[@]}"
      rc=$?
      log_run "$cmd" "" "exit:$rc"
      exit $rc
    fi
    ;;
  # Other commands that accept --path
  tree|viz|detect|move|exclude)
    shift
    log_run "$cmd" "" "started"
    python3 -m desloppify "$cmd" --path "$PROJECT_PATH" "$@"
    rc=$?
    log_run "$cmd" "" "exit:$rc"
    exit $rc
    ;;
  # Show with optional --branch scoping
  show)
    shift
    has_branch=false
    branch_base="main"
    show_args=()
    for arg in "$@"; do
      case "$arg" in
        --branch) has_branch=true ;;
        --branch=*) has_branch=true; branch_base="${arg#--branch=}" ;;
        *) show_args+=("$arg") ;;
      esac
    done

    if $has_branch; then
      # Filter show output to only branch-changed files
      parse_scope_flags "$branch_base"
      resolve_scope_ref "$_BASE"
      ref="$_RESOLVED_REF"
      changed=$(cd "$PROJECT_PATH" && git diff --name-only "$ref" -- '*.vue' '*.ts' 2>/dev/null || true)
      if [[ -z "$changed" ]]; then
        echo "No changed files vs $_BASE"
        exit 0
      fi
      # Run show and filter output to only lines mentioning changed files
      full_output=$(python3 -m desloppify show "${show_args[@]}" 2>/dev/null || true)
      if [[ -z "$full_output" ]]; then
        echo "No issues found."
        exit 0
      fi
      echo "Showing issues for branch-changed files only (vs $_BASE):"
      echo ""
      while IFS= read -r cf; do
        echo "$full_output" | grep -F -i "$cf" || true
      done <<< "$changed"
    else
      exec python3 -m desloppify show "${show_args[@]}"
    fi
    ;;
  # Commands that use --state (no --path flag)
  status|next|backlog|plan|autofix|suppress|review|zone)
    shift
    exec python3 -m desloppify "$cmd" "$@"
    ;;
  # Commands with no path/state args
  config|langs|dev|update-skill)
    shift
    exec python3 -m desloppify "$cmd" "$@"
    ;;
  *)
    # Pass-through for anything else
    exec python3 -m desloppify "$@"
    ;;
esac
