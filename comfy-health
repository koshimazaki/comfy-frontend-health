#!/usr/bin/env bash
set -euo pipefail

# comfy-health — friendly CLI wrapper for desloppify
# Maps user-friendly subcommands to desloppify internals.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_PATH="${COMFY_FRONTEND_PATH:-.}"
LOG_FILE="${COMFY_HEALTH_LOG:-$SCRIPT_DIR/.comfy-health.log}"

# ── Score logging (temporary: track how scores change as we use the tool) ──
# Appends a TSV line: timestamp, branch, commit, subcommand, issue_count, notes
# Inspired by Karpathy's autoresearch ratchet pattern.
# Review .comfy-health.log periodically to see if the tool is helping.
log_run() {
  local subcmd="$1" issues="${2:-}" notes="${3:-}"
  local ts branch commit
  ts=$(date -u +%Y-%m-%dT%H:%M:%SZ)
  branch=$(cd "$PROJECT_PATH" && git symbolic-ref --short HEAD 2>/dev/null || echo "detached")
  commit=$(cd "$PROJECT_PATH" && git rev-parse --short HEAD 2>/dev/null || echo "unknown")
  echo -e "${ts}\t${branch}\t${commit}\t${subcmd}\t${issues}\t${notes}" >> "$LOG_FILE"
}

usage() {
  cat <<'EOF'
comfy-health — ComfyUI frontend health checker

Usage:
  comfy-health scan [options]         Run all detectors, update state, show diff
  comfy-health check [options]        Run subjective review (assess code quality dimensions)
  comfy-health status                 Full project dashboard: score, dimensions, progress
  comfy-health show <pattern>         Dig into issues by file, directory, detector, or ID
  comfy-health next                   Show next priority item from the living plan
  comfy-health backlog                Show broader backlog items
  comfy-health plan                   View/update the living plan
  comfy-health tree                   Annotated codebase tree
  comfy-health viz                    Generate interactive HTML treemap
  comfy-health diff [REF]             Scan only files changed since REF (default: HEAD~1)
  comfy-health branch [BASE]          Scan files changed vs BASE branch (default: main)
  comfy-health doctor                 Self-check: verify deps, config, project setup
  comfy-health lint-review [--base=B] Deterministic code review (fallback for rate-limited code_review)

Options (scan):
  --skip-slow                         Skip slow detectors (duplicates)
  --no-badge                          Skip scorecard image generation
  --profile {objective,full,ci}       Scan profile

Options (check):
  --prepare                           Generate review packet for subjective dimensions
  --import FILE                       Import completed review

Pass-through:
  Any unrecognized subcommand or flag is forwarded directly to desloppify.

Environment:
  COMFY_FRONTEND_PATH                 Project root (default: current directory)

Examples:
  comfy-health scan                   Full repo scan
  comfy-health scan --skip-slow       Skip duplicate detection
  comfy-health check                  Assess subjective quality dimensions
  comfy-health show styling           Show all styling issues
  comfy-health show src/stores/       Show issues in a directory
  comfy-health diff                   Issues in files changed since HEAD~1
  comfy-health diff HEAD~5            Issues in files changed in last 5 commits
  comfy-health branch                 Issues in files changed vs main
  comfy-health branch develop         Issues in files changed vs develop
  comfy-health next                   Get next priority fix
  comfy-health status                 Full dashboard
  comfy-health doctor                 Check deps and project setup
  comfy-health --version              Show version
EOF
}

# Resolve the subcommand
cmd="${1:-}"

case "$cmd" in
  -h|--help|help|"")
    usage
    exit 0
    ;;
  -v|--version|version)
    ver=$(git -C "$SCRIPT_DIR" describe --tags 2>/dev/null || git -C "$SCRIPT_DIR" rev-parse --short HEAD 2>/dev/null || echo "dev")
    echo "comfy-health $ver"
    exit 0
    ;;
  check)
    shift
    # "check" maps to "review --prepare" by default
    # If user passes --import, forward as-is
    # If user already passed --import or --prepare, forward as-is; else default to --prepare
    has_explicit=false
    for arg in "$@"; do
      [[ "$arg" == "--import" || "$arg" == "--prepare" ]] && has_explicit=true
    done
    if $has_explicit; then
      exec python3 -m desloppify review --path "$PROJECT_PATH" "$@"
    else
      exec python3 -m desloppify review --prepare --path "$PROJECT_PATH" "$@"
    fi
    ;;
  # Diff: show known issues for files changed since a ref (default HEAD~1)
  # Separates new files (all issues are yours) from modified files (may be pre-existing)
  diff)
    shift
    strict=false
    ref="HEAD~1"
    for arg in "$@"; do
      if [[ "$arg" == "--strict" ]]; then
        strict=true
      elif [[ "$arg" != -* && "$ref" == "HEAD~1" ]]; then
        ref="$arg"
      fi
    done
    files=$(cd "$PROJECT_PATH" && git diff --name-only "$ref" -- '*.vue' '*.ts' 2>/dev/null)
    if [[ -z "$files" ]]; then
      echo "No changed files since $ref"
      exit 0
    fi

    # Classify files as new (added) or modified
    new_files=$(cd "$PROJECT_PATH" && git diff --name-only --diff-filter=A "$ref" -- '*.vue' '*.ts' 2>/dev/null)
    mod_files=$(cd "$PROJECT_PATH" && git diff --name-only --diff-filter=M "$ref" -- '*.vue' '*.ts' 2>/dev/null)

    new_output=""
    mod_output=""
    new_count=0
    mod_count=0

    # New files: all issues are branch-introduced
    if [[ -n "$new_files" ]]; then
      echo "── New files (all issues are yours) ──"
      while IFS= read -r f; do
        echo "  $f"
        result=$(python3 -m desloppify show "$f" --no-budget 2>/dev/null || true)
        if [[ -n "$result" ]]; then
          new_output+="$result"$'\n'
          new_count=$((new_count + $(echo "$result" | grep -c -v '^$' || true)))
          echo "$result"
        fi
      done <<< "$new_files"
      echo ""
    fi

    # Modified files: get changed line numbers, filter issues
    if [[ -n "$mod_files" ]]; then
      echo "── Modified files (showing issues on changed lines only) ──"
      while IFS= read -r f; do
        # Extract changed line numbers from diff hunks (+side = new lines)
        changed_lines=$(cd "$PROJECT_PATH" && git diff -U0 "$ref" -- "$f" 2>/dev/null | \
          perl -ne 'print "$1\n" if /^@@.*\+(\d+(?:,\d+)?)/' | \
          while IFS=, read -r start count; do
            count=${count:-1}
            for ((i=start; i<start+count; i++)); do echo "$i"; done
          done)
        echo "  $f ($(echo "$changed_lines" | wc -l | tr -d ' ') lines changed)"
        result=$(python3 -m desloppify show "$f" --no-budget 2>/dev/null || true)
        if [[ -n "$result" && -n "$changed_lines" ]]; then
          # Filter: only show lines that match changed line numbers
          filtered=""
          while IFS= read -r line; do
            # Try to extract line number from issue output (common format: :NNN or line NNN)
            line_num=$(echo "$line" | perl -ne 'print "$1\n" if /(?::|line\s+)(\d+)/' | head -1)
            if [[ -z "$line_num" ]]; then
              # No line number found — include it (header/summary line)
              filtered+="$line"$'\n'
            elif echo "$changed_lines" | grep -qx "$line_num"; then
              filtered+="$line"$'\n'
            fi
          done <<< "$result"
          if [[ -n "$filtered" ]]; then
            mod_output+="$filtered"
            mod_count=$((mod_count + $(echo "$filtered" | grep -c -v '^$' || true)))
            echo "$filtered"
          fi
        fi
      done <<< "$mod_files"
      echo ""
    fi

    total=$((new_count + mod_count))
    echo "Summary: $new_count issues in new files, $mod_count issues on changed lines in modified files ($total total)"
    log_run "diff" "$total" "ref:$ref new:$new_count mod:$mod_count"
    if $strict && [[ $total -gt 0 ]]; then
      exit 1
    fi
    ;;
  # Branch: show known issues for files changed vs a base branch (default main)
  # Separates new files from modified files to avoid blaming pre-existing debt on the branch
  branch)
    shift
    strict=false
    base="main"
    for arg in "$@"; do
      if [[ "$arg" == "--strict" ]]; then
        strict=true
      elif [[ "$arg" != -* && "$base" == "main" ]]; then
        base="$arg"
      fi
    done
    merge_base=$(cd "$PROJECT_PATH" && git merge-base "$base" HEAD 2>/dev/null || echo "$base")
    files=$(cd "$PROJECT_PATH" && git diff --name-only "$merge_base" -- '*.vue' '*.ts' 2>/dev/null)
    if [[ -z "$files" ]]; then
      echo "No changed files vs $base"
      exit 0
    fi
    echo "Branch: $(cd "$PROJECT_PATH" && git symbolic-ref --short HEAD 2>/dev/null) vs $base (merge-base: ${merge_base:0:8})"
    echo ""

    # Classify files as new (added) or modified
    new_files=$(cd "$PROJECT_PATH" && git diff --name-only --diff-filter=A "$merge_base" -- '*.vue' '*.ts' 2>/dev/null)
    mod_files=$(cd "$PROJECT_PATH" && git diff --name-only --diff-filter=M "$merge_base" -- '*.vue' '*.ts' 2>/dev/null)

    new_output=""
    mod_output=""
    new_count=0
    mod_count=0

    # New files: all issues are branch-introduced
    if [[ -n "$new_files" ]]; then
      echo "── New files ($(echo "$new_files" | wc -l | tr -d ' ') files — all issues are branch-introduced) ──"
      while IFS= read -r f; do
        echo "  $f"
        result=$(python3 -m desloppify show "$f" --no-budget 2>/dev/null || true)
        if [[ -n "$result" ]]; then
          new_output+="$result"$'\n'
          new_count=$((new_count + $(echo "$result" | grep -c -v '^$' || true)))
          echo "$result"
        fi
      done <<< "$new_files"
      echo ""
    fi

    # Modified files: only show issues on changed lines
    if [[ -n "$mod_files" ]]; then
      echo "── Modified files ($(echo "$mod_files" | wc -l | tr -d ' ') files — showing changed-line issues only) ──"
      while IFS= read -r f; do
        changed_lines=$(cd "$PROJECT_PATH" && git diff -U0 "$merge_base" -- "$f" 2>/dev/null | \
          perl -ne 'print "$1\n" if /^@@.*\+(\d+(?:,\d+)?)/' | \
          while IFS=, read -r start count; do
            count=${count:-1}
            for ((i=start; i<start+count; i++)); do echo "$i"; done
          done)
        echo "  $f ($(echo "$changed_lines" | wc -l | tr -d ' ') lines changed)"
        result=$(python3 -m desloppify show "$f" --no-budget 2>/dev/null || true)
        if [[ -n "$result" && -n "$changed_lines" ]]; then
          filtered=""
          while IFS= read -r line; do
            line_num=$(echo "$line" | perl -ne 'print "$1\n" if /(?::|line\s+)(\d+)/' | head -1)
            if [[ -z "$line_num" ]]; then
              filtered+="$line"$'\n'
            elif echo "$changed_lines" | grep -qx "$line_num"; then
              filtered+="$line"$'\n'
            fi
          done <<< "$result"
          if [[ -n "$filtered" ]]; then
            mod_output+="$filtered"
            mod_count=$((mod_count + $(echo "$filtered" | grep -c -v '^$' || true)))
            echo "$filtered"
          fi
        fi
      done <<< "$mod_files"
      echo ""
    fi

    total=$((new_count + mod_count))
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "Branch-introduced issues: $total ($new_count in new files, $mod_count on changed lines)"
    echo "Files: $(echo "$new_files" | grep -c -v '^$' || true) new, $(echo "$mod_files" | grep -c -v '^$' || true) modified"
    log_run "branch" "$total" "base:$base new:$new_count mod:$mod_count"
    if $strict && [[ $total -gt 0 ]]; then
      exit 1
    fi
    ;;
  # Self-check: verify deps, config, project setup
  doctor)
    errors=0

    # Python version
    if py_ver=$(python3 --version 2>/dev/null | awk '{print $2}'); then
      py_major=$(echo "$py_ver" | cut -d. -f1)
      py_minor=$(echo "$py_ver" | cut -d. -f2)
      if [[ "$py_major" -ge 3 && "$py_minor" -ge 11 ]]; then
        echo "✓ Python $py_ver"
      else
        echo "✗ Python $py_ver (need 3.11+)"
        errors=$((errors + 1))
      fi
    else
      echo "✗ Python 3 not found"
      errors=$((errors + 1))
    fi

    # desloppify importable
    if ds_ver=$(python3 -c "import desloppify; print(desloppify.__version__)" 2>/dev/null); then
      echo "✓ desloppify $ds_ver"
    elif python3 -c "import desloppify" 2>/dev/null; then
      echo "✓ desloppify (version unknown)"
    else
      echo "✗ desloppify not importable (pip install desloppify)"
      errors=$((errors + 1))
    fi

    # Project path and frontend files
    proj=$(cd "$PROJECT_PATH" 2>/dev/null && pwd)
    if [[ -d "$proj" ]]; then
      vue_count=$(find "$proj" -name '*.vue' 2>/dev/null | wc -l | tr -d ' ')
      ts_count=$(find "$proj" -name '*.ts' 2>/dev/null | wc -l | tr -d ' ')
      if [[ "$vue_count" -gt 0 || "$ts_count" -gt 0 ]]; then
        echo "✓ Project: $proj ($vue_count .vue, $ts_count .ts files)"
      else
        echo "✗ Project: $proj (no .vue or .ts files found)"
        errors=$((errors + 1))
      fi
    else
      echo "✗ Project path not found: $PROJECT_PATH"
      errors=$((errors + 1))
    fi

    # .desloppify state directory
    if [[ -d "$proj/.desloppify" ]]; then
      echo "✓ State: $proj/.desloppify"
    else
      echo "⚠ No .desloppify/ state — run 'comfy-health scan' first"
    fi

    # Git
    if command -v git &>/dev/null; then
      if git -C "$proj" rev-parse --is-inside-work-tree &>/dev/null; then
        git_branch=$(git -C "$proj" symbolic-ref --short HEAD 2>/dev/null || echo "detached")
        if git -C "$proj" diff --quiet 2>/dev/null && git -C "$proj" diff --cached --quiet 2>/dev/null; then
          echo "✓ Git: $git_branch branch, clean"
        else
          echo "✓ Git: $git_branch branch, dirty"
        fi
      else
        echo "⚠ Not a git repository: $proj"
      fi
    else
      echo "✗ Git not found"
      errors=$((errors + 1))
    fi

    exit $errors
    ;;
  # Deterministic code review — runs all 6 Vue detectors against diff, formatted
  # like the code-reviewer agent. Zero LLM dependency, no rate limits.
  # Use as fallback when code_review tool hits rate limits.
  lint-review)
    shift
    base="main"
    ref=""
    for arg in "$@"; do
      if [[ "$arg" == --base=* ]]; then
        base="${arg#--base=}"
      elif [[ "$arg" != -* ]]; then
        ref="$arg"
      fi
    done

    # Determine file scope
    if [[ -n "$ref" ]]; then
      merge_base="$ref"
    else
      merge_base=$(cd "$PROJECT_PATH" && git merge-base "$base" HEAD 2>/dev/null || echo "$base")
    fi

    new_files=$(cd "$PROJECT_PATH" && git diff --name-only --diff-filter=A "$merge_base" -- '*.vue' '*.ts' 2>/dev/null || true)
    mod_files=$(cd "$PROJECT_PATH" && git diff --name-only --diff-filter=M "$merge_base" -- '*.vue' '*.ts' 2>/dev/null || true)

    if [[ -z "$new_files" ]]; then new_count=0; else new_count=$(echo "$new_files" | grep -c -v '^$' || echo 0); fi
    if [[ -z "$mod_files" ]]; then mod_count=0; else mod_count=$(echo "$mod_files" | grep -c -v '^$' || echo 0); fi

    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "Deterministic Code Review (lint-review)"
    echo "Scope: ${new_count} new files, ${mod_count} modified files vs ${base}"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""

    # Create temp directory with only changed files for targeted scanning
    tmpdir=$(mktemp -d)
    trap "rm -rf $tmpdir" EXIT

    all_files=$(echo -e "${new_files}\n${mod_files}" | grep -v '^$' | sort -u)

    if [[ -z "$all_files" ]]; then
      echo "No changed .vue/.ts files — nothing to review."
      log_run "lint-review" "0" "base:$base no_changes"
      exit 0
    fi

    # Copy changed files into temp dir preserving structure
    while IFS= read -r f; do
      if [[ -f "$PROJECT_PATH/$f" ]]; then
        mkdir -p "$tmpdir/$(dirname "$f")"
        cp "$PROJECT_PATH/$f" "$tmpdir/$f"
      fi
    done <<< "$all_files"

    # Run all 6 detectors against temp dir (cd into it so paths are relative)
    review_output=$(cd "$tmpdir" && python3 -c "
import sys, json
from pathlib import Path

sys.path.insert(0, '$SCRIPT_DIR/desloppify-fork')
from desloppify.languages.typescript.detectors.vue import (
    detect_composition_api,
    detect_component_violations,
    detect_styling_violations,
    detect_layer_violations,
    detect_conventions,
    detect_reka_patterns,
)

path = Path('.')
all_issues = []
for detect_fn in [
    detect_composition_api,
    detect_component_violations,
    detect_styling_violations,
    detect_layer_violations,
    detect_conventions,
    detect_reka_patterns,
]:
    issues, _ = detect_fn(path)
    all_issues.extend(issues)

print(json.dumps(all_issues))
" 2>/dev/null)

    if [[ -z "$review_output" || "$review_output" == "[]" ]]; then
      echo "✓ All clean — no convention violations in changed files."
      echo ""
      echo "### Branch Health Delta"
      echo "  New files: $new_count (issues: 0)"
      echo "  Modified files: $mod_count (branch-introduced: 0)"
      echo "  Net: CLEAN"
      log_run "lint-review" "0" "base:$base clean"
      exit 0
    fi

    # Parse and format like code-reviewer agent output
    python3 -c "
import json, sys

issues = json.loads('''$review_output''')

# Separate new-file vs modified-file issues
new_files = set('''$new_files'''.strip().split('\n')) if '''$new_files'''.strip() else set()

introduced = []
for issue in issues:
    f = issue['file']
    tag = '[NEW FILE]' if f in new_files else '[CHANGED]'
    introduced.append((issue, tag))

# Sort by severity (critical first)
sev_order = {'critical': 0, 'warning': 1, 'info': 2}
introduced.sort(key=lambda x: sev_order.get(x[0].get('severity', 'info'), 3))

critical_count = sum(1 for i, _ in introduced if i.get('severity') == 'critical')
warning_count = sum(1 for i, _ in introduced if i.get('severity') == 'warning')
info_count = sum(1 for i, _ in introduced if i.get('severity') == 'info')

print('### Branch-Introduced Issues')
print('')
for issue, tag in introduced:
    sev = issue.get('severity', 'warning').upper()
    priority = 'Critical' if sev == 'CRITICAL' else 'Warning' if sev == 'WARNING' else 'Info'
    detector = issue.get('detector', '?')
    print(f'- **{priority}** | {tag}')
    print(f'  **{issue[\"file\"]}:{issue.get(\"line\", 0)}** — {issue[\"summary\"]}')
    print(f'  Rule: {issue.get(\"agents_md_ref\", detector)}')
    print('')

print('### Branch Health Delta')
print('')
print(f'  New files: $new_count (issues: {sum(1 for _, t in introduced if t == \"[NEW FILE]\")})')
print(f'  Modified files: $mod_count (branch-introduced: {sum(1 for _, t in introduced if t == \"[CHANGED]\")})')
print(f'  Critical: {critical_count}, Warning: {warning_count}, Info: {info_count}')
total = len(introduced)
verdict = 'WORSE' if critical_count > 0 else 'NEUTRAL' if warning_count > 0 else 'BETTER'
print(f'  Net: {verdict} ({total} total issues)')
" 2>/dev/null

    total=$(echo "$review_output" | python3 -c "import json,sys; print(len(json.load(sys.stdin)))" 2>/dev/null || echo "?")
    log_run "lint-review" "$total" "base:$base"
    ;;
  # Commands that accept --path
  scan|tree|viz|detect|move|exclude)
    shift
    log_run "$cmd" "" "started"
    python3 -m desloppify "$cmd" --path "$PROJECT_PATH" "$@"
    rc=$?
    log_run "$cmd" "" "exit:$rc"
    exit $rc
    ;;
  # Commands that use --state (no --path flag)
  status|next|backlog|plan|show|autofix|suppress|review|zone)
    shift
    exec python3 -m desloppify "$cmd" "$@"
    ;;
  # Commands with no path/state args
  config|langs|dev|update-skill)
    shift
    exec python3 -m desloppify "$cmd" "$@"
    ;;
  *)
    # Pass-through for anything else
    exec python3 -m desloppify "$@"
    ;;
esac
